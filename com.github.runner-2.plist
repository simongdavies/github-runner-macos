<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.github.runner-2</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__HOME__/scripts/github-runner-wrapper.sh</string>
		<string>__HOME__/github-runner-2</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>

	<key>StandardOutPath</key>
	<string>__HOME__/.github-runner-logs/runner-2-stdout.log</string>

	<key>StandardErrorPath</key>
	<string>__HOME__/.github-runner-logs/runner-2-stderr.log</string>

	<key>WorkingDirectory</key>
	<string>__HOME__/github-runner-2</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>HOME</key>
		<string>__HOME__</string>
	</dict>
</dict>
</plist>
